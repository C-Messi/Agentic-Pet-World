{
  "name": "@cat-house/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean --no-external @cat-house/shared",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint ."
  },
  "dependencies": {
    "@cat-house/shared": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.4.0",
    "gray-matter": "^4.0.3",
    "openai": "^5.10.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
